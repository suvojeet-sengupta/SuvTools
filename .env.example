# Required: Telegram Bot token obtained from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Whisper Model Configuration
WHISPER_MODEL_SIZE=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu

# Concurrency limits for heavy transcription tasks
MAX_CONCURRENT_JOBS=1

# Local directories
DOWNLOAD_DIR=/tmp/transcriptions

# Access Control (optional comma-separated Telegram User IDs/usernames)
# ALLOWED_USERS=123456789,my_telegram_handle
ALLOWED_USERS=
